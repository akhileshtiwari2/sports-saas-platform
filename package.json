{
  "name": "sports-facility-saas",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:den": "turbo run dev --filter=den",
    "dev:playball": "turbo run dev --filter=playball",
    "dev:lineup": "turbo run dev --filter=lineup",
    "dev:slate": "turbo run dev --filter=slate",
    "dev:api": "npm run -w api start:dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=database",
    "db:push": "turbo run db:push --filter=database",
    "db:migrate": "turbo run db:migrate --filter=database",
    "db:studio": "turbo run db:studio --filter=database"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@9.0.0",
  "//": "Run: npm install -g pnpm (or use: npm install)",
  "engines": {
    "node": ">=18.0.0"
  }
}
